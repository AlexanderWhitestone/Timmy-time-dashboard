# ── Timmy Time — Dev Image ─────────────────────────────────────────────────
#
# Lightweight development image with hot-reload and no production overhead.
# Differences from production Dockerfile:
#   - Single stage (no multi-stage build)
#   - No non-root user (simpler file permissions with bind mounts)
#   - No healthcheck (faster startup)
#   - Source mounted as volume (not copied)
#   - Installs dev dependencies (pytest, etc.)
#
# Usage:
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d --build
#   # or:
#   make fresh

FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
        gcc curl git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Poetry
RUN pip install --no-cache-dir poetry poetry-plugin-export

# Copy dependency files only (layer caching)
COPY pyproject.toml poetry.lock ./

# Export and install ALL deps including dev
RUN poetry export --with dev --without-hashes \
        -f requirements.txt -o requirements.txt \
    && pip install --no-cache-dir -r requirements.txt \
    && rm requirements.txt

# Source is bind-mounted in docker-compose.dev.yml, not copied
# Only copy for standalone builds
COPY src/ ./src/
COPY static/ ./static/
COPY tests/ ./tests/

RUN mkdir -p /app/data

ENV PYTHONPATH=/app/src
ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV DEBUG=true

EXPOSE 8000

# Dev default: uvicorn with hot-reload
CMD ["uvicorn", "dashboard.app:app", "--host", "0.0.0.0", "--port", "8000", \
     "--reload", "--reload-dir", "/app/src"]
